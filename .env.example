# Variables de entorno — Pañol Digital
# Copiar a .env y ajustar según entorno

# Base de datos (cambiar password antes de usar)
DATABASE_URL=postgresql://panol:CHANGE_ME@localhost:5432/panol_digital?schema=public

# Backend (generar secrets nuevos antes de producción)
PORT=4000
NODE_ENV=development
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_RANDOM_SECRET
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Frontend
VITE_API_URL=http://localhost:4000

# Email (para recuperación de clave)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@panoldigital.cl

# CORS
FRONTEND_URL=http://localhost:3000
